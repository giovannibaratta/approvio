{
  "name": "@approvio/backend",
  "version": "0.0.1",
  "author": "Giovanni Baratta",
  "license": "PolyForm Noncommercial License 1.0.0",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "start:backend": "dotenv -e .env.local -- nest start backend",
    "start:backend:dev": "dotenv -e .env.local -- nest start backend --watch --debug",
    "deps:start": "./scripts/dependencies.sh start",
    "deps:start:test": "./scripts/dependencies.sh start test",
    "deps:stop": "./scripts/dependencies.sh stop",
    "deps:down": "./scripts/dependencies.sh down",
    "deps:rebuild": "./scripts/dependencies.sh rebuild",
    "db:update-schema": "yarn deps:stop && yarn db:migrate && yarn prisma:pull && yarn prisma:generate",
    "db:migrate": "yarn deps:start && yarn liquibase:update:dev",
    "liquibase:update:dev": "docker run --network host --rm -v ./db-migrations:/liquibase/changelog liquibase/liquibase:4.31.1 --defaultsFile=/liquibase/changelog/liquibase.docker.properties update",
    "liquibase:update:test": "docker run --network host --rm -v ./db-migrations:/liquibase/changelog liquibase/liquibase:4.31.1 --defaultsFile=/liquibase/changelog/integration-test.liquibase.docker.properties update",
    "lint": "yarn eslint --cache --fix .",
    "format:prettier": "yarn prettier --config .prettierrc . --write",
    "prisma:pull": "yarn dotenv -e .env.local -- yarn prisma db pull && prisma-case-format --file prisma/schema.prisma -p --table-case pascal,singular --field-case camel",
    "prisma:generate": "yarn prisma generate",
    "build": "yarn build:backend && yarn build:worker",
    "build:backend": "nest build backend",
    "build:worker": "nest build worker",
    "start:worker": "dotenv -e .env.local -- nest start worker",
    "start:worker:dev": "dotenv -e .env.local -- nest start worker --watch --debug",
    "test:setup": "yarn deps:start:test && yarn prisma:generate && yarn liquibase:update:test",
    "test:jest": "dotenv -e .env.test -- yarn jest --maxWorkers=50%",
    "test": "yarn test:setup && yarn test:jest",
    "test:all": "yarn test:setup && yarn test:jest app/**/*.test.ts",
    "test:bootstrap-env": "yarn ts-node scripts/testing/bootstrap-env.ts",
    "generate:license": "generate-license-file",
    "ai:deps:start": "yarn deps:start --silent",
    "ai:liquibase:update:dev": "yarn liquibase:update:dev --silent",
    "ai:test:setup": "yarn deps:start:test --silent && ./scripts/prisma.sh --silent generate && ./scripts/liquibase.sh --silent update test",
    "ai:test": "yarn ai:test:setup && AI_AGENT=true yarn test:jest",
    "ai:test:all": "yarn ai:test:setup && AI_AGENT=true yarn test:jest app/**/*.test.ts",
    "ai:get-union-literals": "ts-node scripts/ai/get-union-literals.ts"
  },
  "packageManager": "yarn@4.7.0",
  "dependencies": {
    "@approvio/api": "0.0.54",
    "@nestjs/bull": "11.0.4",
    "@nestjs/common": "11.1.23",
    "@nestjs/core": "11.1.24",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.23",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/driver-adapter-utils": "7.8.0",
    "axios": "1.16.1",
    "bull": "4.16.5",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "fp-ts": "2.16.11",
    "ioredis": "5.11.0",
    "jose": "6.2.3",
    "jsonwebtoken": "9.0.3",
    "nodemailer": "8.0.8",
    "openid-client": "6.8.4",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "rate-limiter-flexible": "11.1.0",
    "reflect-metadata": "0.2.2",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.24",
    "@types/chance": "1.1.8",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.19.19",
    "@types/nodemailer": "8.0.0",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "chance": "1.1.13",
    "dotenv-cli": "11.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-prettier": "5.5.5",
    "expect-more-jest": "5.5.0",
    "generate-license-file": "4.2.1",
    "globals": "17.6.0",
    "ioredis": "5.11.0",
    "jest": "30.4.2",
    "license-checker-rseidelsohn": "4.4.2",
    "mailpit-api": "^2.0.0",
    "node-loader": "2.1.0",
    "prettier": "3.8.3",
    "pretty-format": "30.4.1",
    "prisma": "7.8.0",
    "prisma-case-format": "2.2.1",
    "rxjs": "7.8.2",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.5.7",
    "ts-morph": "^28.0.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "webpack": "5.107.2",
    "wiremock": "3.13.2",
    "wiremock-captain": "4.1.3"
  }
}
